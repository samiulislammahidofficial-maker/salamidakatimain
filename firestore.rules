rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: drops
    // Document ID: auto-generated
    // Fields:
    //   - content: string (required, max 500 chars) - The text content of the drop.
    //   - latitude: number (required) - The latitude coordinate.
    //   - longitude: number (required) - The longitude coordinate.
    //   - authorId: string (required) - The UID of the user.
    //   - authorName: string (optional) - The display name of the user.
    //   - authorPhoto: string (optional) - The photo URL of the user.
    //   - createdAt: timestamp (required) - The timestamp when the drop was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isValidDrop(data) {
      return data.keys().hasAll(['content', 'latitude', 'longitude', 'createdAt']) &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 500 &&
             data.latitude is number &&
             data.longitude is number &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /drops/{dropId} {
      // Anyone can read drops
      allow read: if true;
      
      // Anyone can create drops, but they must be valid
      allow create: if isValidDrop(request.resource.data);
      
      // Drops are immutable
      allow update, delete: if false;
    }
  }
}
