rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: universities
    // Fields:
    //   - name: string (required) - Full name of the university
    //   - shortName: string (required) - Short name or acronym
    //
    // Collection: departments
    // Fields:
    //   - name: string (required) - Name of the department
    //   - universityId: string (required) - ID of the university it belongs to
    //
    // Collection: submissions
    // Fields:
    //   - university: string (required) - University ID
    //   - department: string (required) - Department ID
    //   - amount: number (required) - Amount received
    //   - type: string (required, enum: ["money", "food", "both"]) - Type of salami
    //   - comment: string (optional) - User comment
    //   - seniorName: string (optional) - Name of the senior
    //   - seniorFbLink: string (optional) - Facebook link of the senior
    //   - timestamp: number (required) - Creation timestamp
    //   - likes: number (required) - Number of likes
    //
    // Collection: memes
    // Fields:
    //   - expectation: string (optional) - Expected salami
    //   - reality: string (optional) - Actual salami received
    //   - imageUrl: string (optional) - Optional image URL
    //   - likes: number (required) - Number of likes
    //   - timestamp: number (required) - Creation timestamp
    //
    // Subcollection: memes/{memeId}/comments
    // Fields:
    //   - text: string (required) - Comment text
    //   - timestamp: number (required) - Creation timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "common.ipe.mail@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
        (request.resource.data[field] is string &&
          request.resource.data[field].size() >= minLen &&
          request.resource.data[field].size() <= maxLen);
    }

    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidOptionalUrl(field) {
      return !(field in request.resource.data) || isValidUrl(request.resource.data[field]);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidSubmission(data) {
      return hasRequiredFields(['university', 'department', 'amount', 'type', 'timestamp', 'likes']) &&
        hasOnlyAllowedFields(['university', 'department', 'amount', 'type', 'comment', 'seniorName', 'seniorFbLink', 'timestamp', 'likes']) &&
        data.university is string &&
        data.department is string &&
        data.amount is number &&
        data.type in ['money', 'food', 'both'] &&
        isValidOptionalString('comment', 0, 1000) &&
        isValidOptionalString('seniorName', 0, 100) &&
        isValidOptionalUrl('seniorFbLink') &&
        data.timestamp is number &&
        data.likes is number;
    }

    function isValidMeme(data) {
      return hasRequiredFields(['likes', 'timestamp']) &&
        hasOnlyAllowedFields(['expectation', 'reality', 'imageUrl', 'likes', 'timestamp']) &&
        isValidOptionalString('expectation', 0, 500) &&
        isValidOptionalString('reality', 0, 500) &&
        isValidOptionalUrl('imageUrl') &&
        data.likes is number &&
        data.timestamp is number;
    }

    function isValidMemeComment(data) {
      return hasRequiredFields(['text', 'timestamp']) &&
        hasOnlyAllowedFields(['text', 'timestamp']) &&
        isValidString('text', 1, 500) &&
        data.timestamp is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /universities/{universityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && hasRequiredFields(['name', 'universityId']));
    }

    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update: if isAuthenticated() &&
        (
          // Allow anyone to like
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
           request.resource.data.likes == resource.data.likes + 1) ||
          isAdmin()
        );
      allow delete: if isAdmin();
    }

    match /memes/{memeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidMeme(request.resource.data);
      allow update: if isAuthenticated() &&
        (
          // Allow anyone to like
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
           request.resource.data.likes == resource.data.likes + 1) ||
          isAdmin()
        );
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidMemeComment(request.resource.data);
        allow update, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
